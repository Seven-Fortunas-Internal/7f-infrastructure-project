# npm configuration for AI Dashboard
# legacy-peer-deps: ignore optional peer dependency conflicts
# Required because package-lock.json was generated with npm 11 (local dev)
# but CI uses npm 10, which has stricter peer dep resolution.
# Specifically: postcss-load-config's yaml@^2.4.2 optional peer dep
# is not in the lockfile (npm 11 skips it), but npm 10 requires it.
legacy-peer-deps=true
